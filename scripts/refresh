#!/bin/bash

spotify() {
    isplaying=$(/home/oli/Src/i3spotifystatus/getInfo.sh status)
    if [[ $isplaying == "Playing" ]]; then
        artist=$(/home/oli/Src/i3spotifystatus/getInfo.sh artist)
        song=$(/home/oli/Src/i3spotifystatus/getInfo.sh song)
        echo "<span color='#9ec600'>’å╝ $artist - $song</span>"
    fi
}

radio() {
    if [[ -f "/home/oli/Dev/bash/station" ]]; then 
        station=$(cat ~/Dev/bash/station)
        if [[ ! -z $station ]]; then
            echo "<span color='#9ec600'>$station</span>"
        fi
    fi
}

network_stat() {
    ip_addr=$(hostname -I | awk -F' ' '{ print $1 }')
    echo "¾░®Ā $ip_addr"
}

battery() {
    status=$(cat /sys/class/power_supply/BAT0/status)
    capacity=$(cat /sys/class/power_supply/BAT0/capacity)
    case "$status" in
        "Not charging")
            status_icon="¾▒¤ó"
            ;;
        "Discharging")
            status_icon="¾▒¤ż"
            ;;
        "Charging")
            status_icon="’ć” "
            ;;
        *)
            ;;
    esac
    echo "$status_icon $capacity%"
}

weather() {
    if [[ -f "/home/oli/Src/ansiweather/weather" ]]; then 
        weather=$(cat ~/Src/ansiweather/weather)
        if [[ -z $weather ]]; then
            echo "¾░¢É ----"
        else
            echo $weather
        fi
    else
        echo "¾░¢É ----"
    fi

}

volume_pa() {
    if [[ -f "/home/oli/Dev/bash/vol" ]]; then 
        cat ~/Dev/bash/vol
    else
        echo "<span color='#83cafa'>¾░Ää --</span>"
    fi
}

keyboard() {
    if [[ -f "/home/oli/Dev/bash/xkb" ]]; then 
        cat ~/Dev/bash/xkb
    else
        echo "<span color='#83cafa'>’å½ gr</span>"
    fi
}

dayinf() {
	dte=$(date +"%d.%m")
    echo "’ü│ $dte"
}

clock() {
	time=$(date +"%H:%M")
	echo "<span color='#83cafa'>’ĆŚ $time</span>"
}

main() {
    xsetroot -name "$(spotify)$(radio)    $(network_stat)    $(weather)    $(dayinf)    $(volume_pa)    $(keyboard)    $(battery)    $(clock)"
}

main
